# =============================================================================
# Docker Build Context Exclusions
# =============================================================================
# Reduce build context size and prevent unnecessary files from being copied.

# -----------------------------------------------------------------------------
# Git and Version Control
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes

# -----------------------------------------------------------------------------
# Python Caches and Build Artifacts
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# -----------------------------------------------------------------------------
# Virtual Environments
# -----------------------------------------------------------------------------
.venv/
venv/
ENV/
env/

# -----------------------------------------------------------------------------
# Testing and Coverage
# -----------------------------------------------------------------------------
tests/
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
pytest.ini

# -----------------------------------------------------------------------------
# IDE and Editor Files
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.cursor/

# -----------------------------------------------------------------------------
# Documentation (not needed in runtime image)
# -----------------------------------------------------------------------------
docs/
*.md
!README.md
*.mdx

# -----------------------------------------------------------------------------
# Development Files
# -----------------------------------------------------------------------------
.pre-commit-config.yaml
.ruff_cache/
.mypy_cache/
.dmypy.json
dmypy.json
Makefile
Taskfile.yml

# -----------------------------------------------------------------------------
# Local Data and Secrets
# -----------------------------------------------------------------------------
.env
.env.*
*.local
.indexed/
*.toml.backup

# -----------------------------------------------------------------------------
# Docker Files (prevent recursive context)
# -----------------------------------------------------------------------------
Dockerfile*
docker-compose*.yml
.dockerignore

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
.DS_Store
Thumbs.db
